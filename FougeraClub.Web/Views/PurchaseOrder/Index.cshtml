@model IEnumerable<FougeraClub.Application.DTOs.PurchaseOrderDto>
@using FougeraClub.Domain.Entities

@{
    ViewData["Title"] = "إدارة أوامر الشراء";
    var suppliers = ViewBag.Suppliers as IEnumerable<Supplier> ?? Enumerable.Empty<Supplier>();
}

<div class="container-fluid rtl-container mt-3">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="/Admin/Home/Index">نادي فوجيرا</a></li>
                        <li class="breadcrumb-item active">إدارة أوامر الشراء</li>
                    </ol>
                </div>
                <h4 class="page-title">إدارة أوامر الشراء</h4>
            </div>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-end mb-3">
                        <a href="/Admin/PurchaseOrder/AddEdit" class="btn btn-success btn-rounded mb-0">
                            <i class="ri-add-circle-fill me-1"></i> إضافة أمر شراء
                        </a>
                    </div>

                    <form method="get" onsubmit="return validateDates()" class="row g-2 align-items-end">
                        <div class="col-xl-3 col-lg-4 col-md-6">
                            <label class="form-label fw-bold">اسم المورد</label>
                            <select name="supplierName" class="form-select">
                                <option value="">اسم المورد</option>
                                @foreach (var supplier in suppliers)
                                {
                                    if (string.Equals((string?)ViewBag.SupplierName, supplier.Name, StringComparison.Ordinal))
                                    {
                                        <option value="@supplier.Name" selected>@supplier.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@supplier.Name">@supplier.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-xl-2 col-lg-4 col-md-6">
                            <label class="form-label fw-bold">من</label>
                            <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control">
                        </div>

                        <div class="col-xl-2 col-lg-4 col-md-6">
                            <label class="form-label fw-bold">إلى</label>
                            <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control">
                        </div>

                        <div class="col-xl-2 col-lg-3 col-md-4 col-6">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="ri-search-line"></i> بحث
                            </button>
                        </div>

                        <div class="col-xl-2 col-lg-3 col-md-4 col-6">
                            <button type="button" onclick="window.print()" class="btn btn-secondary w-100">
                                <i class="ri-printer-line"></i> طباعة
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-centered table-hover mb-0 po-table-rtl">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center po-col-number">رقم أمر الشراء</th>
                                    <th class="text-center po-col-supplier">اسم المورد</th>
                                    <th class="text-center po-col-date">التاريخ</th>
                                    <th class="text-center po-col-actions">أدوات التحكم</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">لا توجد سجلات حالياً</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="text-center fw-bold text-primary">@item.OrderNumber</td>
                                            <td class="text-center">@item.SupplierName</td>
                                            <td class="text-center">@item.OrderDate.ToString("dd-MM-yyyy")</td>
                                            <td>
                                                <div class="d-flex justify-content-center gap-1">
                                                    <a href="javascript:void(0)" onclick="window.print()" class="btn btn-sm btn-soft-secondary" title="طباعة">
                                                        <i class="ri-printer-line"></i>
                                                    </a>
                                                    <a asp-action="AddEdit" asp-route-id="@item.Id" class="btn btn-sm btn-soft-primary" title="تعديل">
                                                        <i class="ri-edit-2-line"></i>
                                                    </a>
                                                    <a href="#" class="btn btn-sm btn-soft-danger" title="حذف">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rtl-container {
        direction: rtl;
        text-align: right;
    }

    .page-title-box {
        padding: 20px 0;
    }

    .btn-soft-primary {
        background-color: rgba(114, 124, 245, 0.1);
        color: #727cf5;
    }

    .btn-soft-danger {
        background-color: rgba(250, 92, 124, 0.1);
        color: #fa5c7c;
    }

    .btn-soft-secondary {
        background-color: rgba(108, 117, 125, 0.12);
        color: #6c757d;
    }

    .btn-rounded {
        border-radius: 30px;
    }

    .po-table-rtl {
        direction: rtl;
    }

    .po-table-rtl th,
    .po-table-rtl td {
        vertical-align: middle;
        padding-top: 0.85rem;
        padding-bottom: 0.85rem;
        white-space: nowrap;
    }

    .po-col-number {
        width: 14%;
        min-width: 130px;
    }

    .po-col-supplier {
        width: 46%;
        min-width: 320px;
    }

    .po-col-date {
        width: 20%;
        min-width: 150px;
    }

    .po-col-actions {
        width: 20%;
        min-width: 190px;
    }

    @@media print {
        .btn, .card-body form, .breadcrumb, .side-nav, .custom-navbar {
            display: none !important;
        }

        .card {
            border: none;
            box-shadow: none;
        }

        .table {
            width: 100% !important;
            border: 1px solid #ddd;
        }
    }
</style>

<script>
    function validateDates() {
        const fromDate = document.querySelector('input[name="fromDate"]').value;
        const toDate = document.querySelector('input[name="toDate"]').value;

        if (fromDate && toDate && fromDate > toDate) {
            toastr.error('عذراً، يجب أن يكون تاريخ "من" أقل من أو يساوي تاريخ "إلى"', 'خطأ في التاريخ');
            return false;
        }

        return true;
    }
</script>
